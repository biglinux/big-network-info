pkgname=big-network-info
pkgdesc="Network scanner and diagnostics tool for BigLinux"
pkgver=$(date +%y.%m.%d)
pkgrel=1
arch=('any')
url="https://github.com/biglinux/$pkgname"
license=('GPL-2.0-or-later')
source=("git+${url}.git")
depends=(
    'libadwaita'
    'python-gobject'
    'python-cairo'
    'python-netifaces'
    'python-requests'
    'python-reportlab'
    'networkmanager'
    'iproute2'
    'xdg-utils'
)
optdepends=(
    'avahi: mDNS / Zeroconf name resolution'
    'arp-scan: IEEE OUI vendor database for MAC lookup'
)
makedepends=(
    'python-build'
    'python-installer'
    'python-uv-build'
    'gettext'
)
md5sums=(SKIP)

if [ -e "${pkgname}.install" ]; then
    install=${pkgname}.install
fi

build() {
    cd "${srcdir}/${pkgname}"
    python -m build --wheel --no-isolation --skip-dependency-check
}

package() {
    cd "${srcdir}/${pkgname}"

    # Install the Python wheel (registers the `big-network-info` entrypoint via
    # [project.gui-scripts] in pyproject.toml).
    python -m installer --destdir="$pkgdir" dist/*.whl

    # Install non-Python assets (desktop file, icons, pre-compiled .mo files).
    if [ -d "usr" ]; then
        cp -r usr/. "${pkgdir}/usr/"
    fi

    if [ -d "etc" ]; then
        cp -r etc "${pkgdir}/"
    fi

    if [ -d "opt" ]; then
        cp -r opt "${pkgdir}/"
    fi

    # Install the license file per Arch packaging guidelines.
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
